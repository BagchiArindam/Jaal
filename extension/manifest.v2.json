{
  "manifest_version": 2,
  "name": "Jaal",
  "version": "0.1.0",
  "description": "Web-inspection and reverse-DOM toolkit \u2014 skeleton inspector, list scraping, network recorder.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "<all_urls>",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Jaal tools",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jaal@jaal",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/net-recorder-injector.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "shared/logger.js",
    "shared/net-hooks.js",
    "content/net-recorder-main.js"
  ]
}