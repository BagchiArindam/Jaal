{
  "manifest_version": 2,
  "name": "Jaal",
  "version": "0.1.0",
  "description": "Web-inspection and reverse-DOM toolkit — skeleton inspector, list scraping, network recorder.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Jaal",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "jaal@jaal",
      "strict_min_version": "109.0"
    }
  }
}
