{
  "manifest_version": 3,
  "name": "Jaal",
  "version": "0.1.0",
  "description": "Web-inspection and reverse-DOM toolkit \u00e2\u20ac\u201d skeleton inspector, list scraping, network recorder.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Jaal",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "shared/logger.js",
        "shared/net-hooks.js",
        "content/net-recorder-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}